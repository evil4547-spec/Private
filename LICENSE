<script>
function login() {
let u = document.getElementById("user").value;
let p = document.getElementById("pass").value;

if(u === "Nada" && p === "12345678") {
document.body.innerHTML = `
<h1>بصراحة...</h1>
<p>انا لسه معجب بيكي ولسه حاسس بحاجه ناحيتك ولسه عايزك فحياتي انتي اي الكلام  ❤️</p>
<p>وحابب نبقى أقرب</p>
`;
} else {
document.getElementById("msg").innerText = "حاولي تاني 😏";
}
}
</script>

